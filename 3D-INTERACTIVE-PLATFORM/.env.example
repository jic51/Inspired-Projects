# Copy this file to .env.local and fill in your values

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cloudflare R2 — https://dash.cloudflare.com → R2
CLOUDFLARE_R2_ACCOUNT_ID=abc123
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=scenix-media
CLOUDFLARE_R2_PUBLIC_DOMAIN=https://media.scenix.app  # optional custom domain

# World Labs API — https://worldlabs.ai
WORLDLABS_API_KEY=wl_...

# Google Gemini — https://aistudio.google.com
GEMINI_API_KEY=AIza...

# Stripe (optional for MVP) — https://stripe.com/dashboard
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
